{
  "tasks": {
    "start:old": "deno run -A npm:concurrently \"npm start --prefix back-end\" \"npm run start --prefix frontend\"",
    "start": "npm run start --prefix frontend & ./rust-back-end/target/debug/rust-back-end",
    "start:server": "./rust-back-end/target/debug/rust-back-end",
    "start:web": "npm run start --prefix frontend",
    "lint": "deno lint",
    "fmt": "deno fmt"
  },
  "lint": {
    "files": {
      "exclude": [
        "frontend/dist",
        "rust-back-end/target"
      ]
    }
  },
  "fmt": {
    "files": {
      "exclude": [
        "frontend/dist",
        "rust-back-end/target"
      ]
    }
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": [
      "esnext",
      "dom"
    ],
    "types": [
      "npm:@types/node"
    ]
  },
  "imports": {
    "@eslint/js": "npm:@eslint/js@^9.39.2",
    "@std/assert": "jsr:@std/assert@1",
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@^5.1.2",
    "axios": "npm:axios@1.13.2",
    "express": "npm:express@^5.2.1",
    "react": "npm:react@19.2.0",
    "react-dom": "npm:react-dom@19.2.0",
    "react-dom/client": "npm:react-dom@19.2.0/client",
    "@mui/material": "npm:@mui/material@7.3.6",
    "@mui/icons-material": "npm:@mui/icons-material@7.3.6",
    "@emotion/react": "npm:@emotion/react@11.14.0",
    "@emotion/styled": "npm:@emotion/styled@11.14.1"
  }
}